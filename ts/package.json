{
  "name": "@theory-cloud/apptheory",
  "version": "1.17.0",
  "description": "AppTheory — multi-language serverless application framework (TypeScript package)",
  "type": "module",
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run check && node ./scripts/verify-openapi.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint --max-warnings=0 --report-unused-disable-directives \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "check": "npm run typecheck && npm run lint && npm run format:check"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@aws-sdk/client-apigatewaymanagementapi": "^3.1015.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1081.0",
    "@aws-sdk/client-lambda-microvms": "^3.1075.0",
    "@aws-sdk/client-s3": "^3.1015.0",
    "@aws-sdk/client-s3vectors": "^3.1081.0",
    "@theory-cloud/tabletheory-ts": "https://github.com/theory-cloud/TableTheory/releases/download/v2.0.3/theory-cloud-tabletheory-ts-2.0.3.tgz#sha512-kRqWmWHnF9y7rfVzoIIknKAbiqVN6W0X+oTA71u29jdMBhp7MG88Lv4pl0bhfqLY8zCJdc/JIxT/h6/0n27PaA=="
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/node": "^20.19.43",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^17.4.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
