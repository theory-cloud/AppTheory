const fs = require("node:fs");
const path = require("node:path");

const cdk = require("aws-cdk-lib");
const lambda = require("aws-cdk-lib/aws-lambda");
const { AppTheoryFunction, AppTheoryHttpApi } = require("@theory-cloud/apptheory-cdk");

function copyDir(src, dest) {
  fs.mkdirSync(dest, { recursive: true });
  for (const entry of fs.readdirSync(src, { withFileTypes: true })) {
    const from = path.join(src, entry.name);
    const to = path.join(dest, entry.name);
    if (entry.isDirectory()) copyDir(from, to);
    if (entry.isFile()) fs.copyFileSync(from, to);
  }
}

class __APP_CLASS__Stack extends cdk.Stack {
  constructor(scope, id, props) {
    super(scope, id, props);
    const projectRoot = path.resolve(__dirname, "..");
    const handler = new AppTheoryFunction(this, "Handler", {
      runtime: lambda.Runtime.NODEJS_24_X,
      handler: "handler.handler",
      code: lambda.Code.fromAsset(projectRoot, {
        bundling: {
          image: lambda.Runtime.NODEJS_24_X.bundlingImage,
          command: [
            "bash",
            "-c",
            [
              "mkdir -p /asset-output/node_modules/@theory-cloud",
              "cp -R /asset-input/src/* /asset-output/",
              "cp /asset-input/package.json /asset-output/package.json",
              "cp -R /asset-input/node_modules/@theory-cloud/apptheory /asset-output/node_modules/@theory-cloud/apptheory",
            ].join(" && "),
          ],
          local: {
            tryBundle(outputDir) {
              fs.rmSync(outputDir, { force: true, recursive: true });
              fs.mkdirSync(path.join(outputDir, "node_modules", "@theory-cloud"), { recursive: true });
              copyDir(path.join(projectRoot, "src"), outputDir);
              fs.copyFileSync(path.join(projectRoot, "package.json"), path.join(outputDir, "package.json"));
              copyDir(
                path.join(projectRoot, "node_modules", "@theory-cloud", "apptheory"),
                path.join(outputDir, "node_modules", "@theory-cloud", "apptheory"),
              );
              return true;
            },
          },
        },
      }),
      environment: { APPTHEORY_TIER: "p2" },
    });
    const api = new AppTheoryHttpApi(this, "Api", { handler: handler.fn, apiName: "__APP_PACKAGE__" });
    new cdk.CfnOutput(this, "ApiUrl", { value: api.api.apiEndpoint });
  }
}

const app = new cdk.App();
new __APP_CLASS__Stack(app, "__APP_CLASS__Stack");
