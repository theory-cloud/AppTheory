{
  "id": "p2.observability.emf_error",
  "tier": "p2",
  "name": "EMF request error metrics include deterministic duration and error count",
  "setup": {
    "routes": [
      {
        "method": "GET",
        "path": "/duration-error",
        "handler": "advance_clock_13ms_internal"
      }
    ]
  },
  "input": {
    "request": {
      "method": "GET",
      "path": "/duration-error",
      "query": {},
      "headers": {
        "x-tenant-id": [
          "tenant_err"
        ]
      },
      "body": {
        "encoding": "utf8",
        "value": ""
      },
      "is_base64": false
    }
  },
  "expect": {
    "response": {
      "status": 500,
      "headers": {
        "content-type": [
          "application/json; charset=utf-8"
        ],
        "x-request-id": [
          "req_test_123"
        ]
      },
      "cookies": [],
      "body_json": {
        "error": {
          "code": "app.internal",
          "message": "internal error",
          "request_id": "req_test_123"
        }
      },
      "is_base64": false
    },
    "logs": [
      {
        "level": "error",
        "event": "request.completed",
        "request_id": "req_test_123",
        "tenant_id": "tenant_err",
        "method": "GET",
        "path": "/duration-error",
        "status": 500,
        "error_code": "app.internal",
        "duration_ms": 13
      }
    ],
    "metrics": [
      {
        "name": "apptheory.request",
        "value": 1,
        "duration_ms": 13,
        "tags": {
          "method": "GET",
          "path": "/duration-error",
          "status": "500",
          "error_code": "app.internal",
          "tenant_id": "tenant_err"
        }
      }
    ],
    "spans": [
      {
        "name": "http GET /duration-error",
        "attributes": {
          "http.method": "GET",
          "http.route": "/duration-error",
          "http.status_code": "500",
          "request.id": "req_test_123",
          "tenant.id": "tenant_err",
          "error.code": "app.internal"
        }
      }
    ],
    "emf_logs": [
      "{\"_aws\":{\"Timestamp\":13,\"CloudWatchMetrics\":[{\"Namespace\":\"AppTheory\",\"Dimensions\":[[\"service\",\"method\",\"path\",\"status\",\"tenant_id\",\"error_code\"]],\"Metrics\":[{\"Name\":\"RequestCount\",\"Unit\":\"Count\"},{\"Name\":\"RequestDuration\",\"Unit\":\"Milliseconds\"},{\"Name\":\"RequestErrors\",\"Unit\":\"Count\"}]}]},\"service\":\"apptheory\",\"method\":\"GET\",\"path\":\"/duration-error\",\"status\":\"500\",\"tenant_id\":\"tenant_err\",\"error_code\":\"app.internal\",\"RequestCount\":1,\"RequestDuration\":13,\"RequestErrors\":1}"
    ]
  }
}
