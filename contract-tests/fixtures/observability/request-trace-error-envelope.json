{
  "id": "p2.observability.trace_error_envelope",
  "tier": "p2",
  "name": "Trace propagation adds trace_id to P2 observability records and error envelopes",
  "setup": {
    "routes": [
      {
        "method": "GET",
        "path": "/trace-error",
        "handler": "advance_clock_13ms_internal"
      }
    ]
  },
  "input": {
    "request": {
      "method": "GET",
      "path": "/trace-error",
      "query": {},
      "headers": {
        "traceparent": [
          "00-11111111111111111111111111111111-2222222222222222-01"
        ],
        "x-tenant-id": [
          "tenant_trace_error"
        ]
      },
      "body": {
        "encoding": "utf8",
        "value": ""
      },
      "is_base64": false
    }
  },
  "expect": {
    "response": {
      "status": 500,
      "headers": {
        "content-type": [
          "application/json; charset=utf-8"
        ],
        "x-request-id": [
          "req_test_123"
        ]
      },
      "cookies": [],
      "body_json": {
        "error": {
          "code": "app.internal",
          "message": "internal error",
          "request_id": "req_test_123",
          "trace_id": "11111111111111111111111111111111"
        }
      },
      "is_base64": false
    },
    "logs": [
      {
        "level": "error",
        "event": "request.completed",
        "request_id": "req_test_123",
        "trace_id": "11111111111111111111111111111111",
        "tenant_id": "tenant_trace_error",
        "method": "GET",
        "path": "/trace-error",
        "status": 500,
        "error_code": "app.internal",
        "duration_ms": 13
      }
    ],
    "metrics": [
      {
        "name": "apptheory.request",
        "value": 1,
        "duration_ms": 13,
        "tags": {
          "method": "GET",
          "path": "/trace-error",
          "status": "500",
          "error_code": "app.internal",
          "tenant_id": "tenant_trace_error"
        }
      }
    ],
    "spans": [
      {
        "name": "http GET /trace-error",
        "attributes": {
          "http.method": "GET",
          "http.route": "/trace-error",
          "http.status_code": "500",
          "request.id": "req_test_123",
          "trace.id": "11111111111111111111111111111111",
          "tenant.id": "tenant_trace_error",
          "error.code": "app.internal"
        }
      }
    ]
  }
}
