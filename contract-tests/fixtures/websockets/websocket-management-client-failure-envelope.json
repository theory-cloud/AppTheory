{
  "id": "m2.websocket.management_client_failure_envelope",
  "tier": "m2",
  "name": "WebSocket: management client send failures return the internal error envelope and keep attempted call evidence",
  "setup": {
    "websockets": [
      {
        "route_key": "$default",
        "handler": "ws_default_send_json_fail"
      }
    ]
  },
  "input": {
    "aws_event": {
      "source": "apigw_websocket",
      "event": {
        "path": "/",
        "httpMethod": "POST",
        "headers": {
          "content-type": "application/json"
        },
        "queryStringParameters": {},
        "requestContext": {
          "stage": "dev",
          "requestId": "ws-req-send-fail",
          "connectionId": "conn-send-fail",
          "domainName": "example.execute-api.us-east-1.amazonaws.com",
          "eventType": "MESSAGE",
          "routeKey": "$default"
        },
        "body": "ping",
        "isBase64Encoded": false
      }
    }
  },
  "expect": {
    "response": {
      "status": 500,
      "headers": {
        "content-type": [
          "application/json; charset=utf-8"
        ]
      },
      "cookies": [],
      "body_json": {
        "error": {
          "code": "app.internal",
          "message": "internal error"
        }
      },
      "is_base64": false
    },
    "ws_calls": [
      {
        "op": "post_to_connection",
        "endpoint": "https://example.execute-api.us-east-1.amazonaws.com/dev",
        "connection_id": "conn-send-fail",
        "data": {
          "encoding": "utf8",
          "value": "{\"ok\":true}"
        }
      }
    ]
  }
}
