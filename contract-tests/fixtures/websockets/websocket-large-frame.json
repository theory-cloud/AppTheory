{
  "id": "m2.websocket.large_frame_body",
  "tier": "m2",
  "name": "WebSocket: large message frames are normalized into the WebSocket context body",
  "setup": {
    "websockets": [
      {
        "route_key": "$default",
        "handler": "ws_default_body_size"
      }
    ]
  },
  "input": {
    "aws_event": {
      "source": "apigw_websocket",
      "event": {
        "path": "/",
        "httpMethod": "POST",
        "headers": {
          "content-type": "application/json"
        },
        "queryStringParameters": {},
        "requestContext": {
          "stage": "dev",
          "requestId": "ws-req-large-frame",
          "connectionId": "conn-large-frame",
          "domainName": "example.execute-api.us-east-1.amazonaws.com",
          "eventType": "MESSAGE",
          "routeKey": "$default"
        },
        "body": "",
        "isBase64Encoded": false
      }
    }
  },
  "expect": {
    "response": {
      "status": 200,
      "headers": {
        "content-type": [
          "application/json; charset=utf-8"
        ]
      },
      "cookies": [],
      "body_json": {
        "handler": "default",
        "body_len": 32768,
        "route_key": "$default",
        "event_type": "MESSAGE",
        "connection_id": "conn-large-frame",
        "management_endpoint": "https://example.execute-api.us-east-1.amazonaws.com/dev",
        "request_id": "ws-req-large-frame"
      },
      "is_base64": false
    }
  }
}
