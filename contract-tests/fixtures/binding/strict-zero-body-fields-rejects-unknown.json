{
  "id": "p0.binding.strict_zero_body_fields_rejects_unknown",
  "tier": "p0",
  "name": "Strict JSON rejects unknown body keys when no body fields are declared",
  "setup": {
    "routes": [
      {
        "method": "POST",
        "path": "/strict-query-only",
        "handler": "bind_strict_query_only"
      }
    ]
  },
  "input": {
    "request": {
      "method": "POST",
      "path": "/strict-query-only",
      "query": {
        "count": [
          "7"
        ]
      },
      "headers": {
        "content-type": [
          "application/json"
        ]
      },
      "body": {
        "encoding": "utf8",
        "value": "{\"extra\":true}"
      },
      "is_base64": false
    }
  },
  "expect": {
    "response": {
      "status": 400,
      "headers": {
        "content-type": [
          "application/json; charset=utf-8"
        ]
      },
      "cookies": [],
      "body_json": {
        "error": {
          "code": "app.bad_request",
          "message": "invalid body binding: extra",
          "status_code": 400,
          "details": {
            "source": "body",
            "name": "extra"
          }
        }
      },
      "is_base64": false
    }
  }
}
