{
  "id": "p2.appsync.context_metadata",
  "tier": "p2",
  "name": "AppSync context preserves resolver metadata",
  "setup": {
    "routes": [
      { "method": "POST", "path": "/createThing", "handler": "echo_appsync_context" }
    ]
  },
  "input": {
    "aws_event": {
      "source": "appsync",
      "event": {
        "arguments": { "id": "thing_123" },
        "identity": { "username": "user_1" },
        "source": { "id": "parent_1" },
        "request": {
          "headers": {
            "x-appsync": "yes"
          }
        },
        "info": {
          "fieldName": "createThing",
          "parentTypeName": "Mutation",
          "variables": {
            "tenantId": "tenant_1"
          }
        },
        "prev": {
          "id": "prev_1"
        },
        "stash": {
          "trace": "abc123"
        }
      }
    }
  },
  "expect": {
    "output_json": {
      "field_name": "createThing",
      "parent_type_name": "Mutation",
      "arguments": {
        "id": "thing_123"
      },
      "identity": {
        "username": "user_1"
      },
      "source": {
        "id": "parent_1"
      },
      "variables": {
        "tenantId": "tenant_1"
      },
      "stash": {
        "trace": "abc123"
      },
      "prev": {
        "id": "prev_1"
      },
      "request_headers": {
        "x-appsync": "yes"
      },
      "raw_event_field": "createThing",
      "ctx_trigger_type": "appsync",
      "ctx_field_name": "createThing",
      "ctx_parent_type": "Mutation",
      "ctx_request_headers": {
        "x-appsync": "yes"
      }
    }
  }
}
