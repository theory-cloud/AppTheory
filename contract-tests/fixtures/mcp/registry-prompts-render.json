          "body_json": {
            "jsonrpc": "2.0",
            "id": "init",
            "result": {
              "protocolVersion": "2025-11-25",
              "capabilities": {
                "prompts": {}
              },
              "serverInfo": {
                "name": "ContractMCP",
                "version": "sp09"
              }
            }
          }
        },
        {
          "status": 200,
          "headers": {
            "x-request-id": [
              "req_mcp_123"
            ],
            "content-type": [
              "application/json"
            ]
          },
          "cookies": [],
          "is_base64": false,
          "body_json": {
            "jsonrpc": "2.0",
            "id": "list",
            "result": {
              "prompts": [
                {
                  "name": "greet",
                  "title": "Greeting",
                  "description": "Render a greeting",
                  "arguments": [
                    {
                      "name": "name",
                      "description": "Name to greet",
                      "required": true
                    }
                  ]
                }
              ]
            }
          }
        },
        {
          "status": 200,
          "headers": {
            "x-request-id": [
              "req_mcp_123"
            ],
            "content-type": [
              "application/json"
            ]
          },
          "cookies": [],
          "is_base64": false,
          "body_json": {
            "jsonrpc": "2.0",
            "id": "get",
            "result": {
              "description": "Rendered greeting",
              "messages": [
                {
                  "role": "user",
                  "content": {
                    "type": "text",
                    "text": "Hello, Ada."
                  }
                }
              ]
            }
          }
        },
        {
          "status": 200,
          "headers": {
            "x-request-id": [
              "req_mcp_123"
            ],
            "content-type": [
              "application/json"
            ]
          },
          "cookies": [],
          "is_base64": false,
          "body_json": {
            "jsonrpc": "2.0",
            "id": "missing",
            "error": {
