            "body": {
              "encoding": "utf8",
              "value": "{\"jsonrpc\":\"2.0\",\"id\":\"templates\",\"method\":\"resources/templates/list\"}"
            },
            "is_base64": false
          }
        },
        {
          "name": "resources_read_missing",
          "request": {
            "method": "POST",
