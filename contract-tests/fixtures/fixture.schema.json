{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://theory.cloud/apptheory/contract-tests/fixture.schema.json",
  "title": "AppTheory contract fixture",
  "description": "Internal meta-contract for AppTheory cross-language contract test fixtures.",
  "type": "object",
  "required": ["id", "tier", "name", "expect"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(p0|p1|p2|m1|m2|m3|m12|m14|m15|m16|mcp|oauth)(\\.|_)[A-Za-z0-9_.-]+$"
    },
    "tier": { "$ref": "#/$defs/tier" },
    "name": { "type": "string", "minLength": 1 },
    "setup": { "$ref": "#/$defs/setup" },
    "input": { "$ref": "#/$defs/input" },
    "expect": { "$ref": "#/$defs/expect" }
  },
  "$defs": {
    "tier": {
      "type": "string",
      "enum": ["p0", "p1", "p2", "m1", "m2", "m3", "m12", "m14", "m15", "m16", "mcp", "oauth"]
    },
    "stringArray": {
      "type": "array",
      "items": { "type": "string" }
    },
    "stringMap": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "route": {
      "type": "object",
      "required": ["method", "path", "handler"],
      "additionalProperties": false,
      "properties": {
        "method": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "handler": {
          "anyOf": [
            { "type": "string", "minLength": 1 },
            { "type": "null" }
          ]
        },
        "auth_required": { "type": "boolean" }
      }
    },
    "namedHandler": {
      "type": "object",
      "required": ["handler"],
      "additionalProperties": true,
      "properties": {
        "handler": { "type": "string", "minLength": 1 }
      }
    },
    "setup": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "routes": { "type": "array", "items": { "$ref": "#/$defs/route" } },
        "middlewares": { "$ref": "#/$defs/stringArray" },
        "cors": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "allow_credentials": { "type": "boolean" },
            "allowed_origins": { "$ref": "#/$defs/stringArray" }
          }
        },
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max_request_bytes": { "type": "integer" },
            "max_response_bytes": { "type": "integer" }
          }
        },
        "http_error_format": { "type": "string" },
        "sqs": { "type": "array", "items": { "$ref": "#/$defs/namedHandler" } },
        "eventbridge": { "type": "array", "items": { "$ref": "#/$defs/namedHandler" } },
        "dynamodb": { "type": "array", "items": { "$ref": "#/$defs/namedHandler" } },
        "kinesis": { "type": "array", "items": { "$ref": "#/$defs/namedHandler" } },
        "sns": { "type": "array", "items": { "$ref": "#/$defs/namedHandler" } },
        "websockets": { "type": "array", "items": { "$ref": "#/$defs/namedHandler" } },
        "logging_profile": { "type": "object", "additionalProperties": true },
        "environment": { "$ref": "#/$defs/stringMap" },
        "openapi": { "$ref": "#/$defs/openapiSpec" },
        "microvm_contract": { "type": "object", "additionalProperties": true },
        "microvm_controller_route": { "type": "object", "additionalProperties": true },
        "microvm_execution_role": { "type": "object", "additionalProperties": true },
        "mcp": { "$ref": "#/$defs/mcpSetup" },
        "oauth": { "$ref": "#/$defs/oauthSetup" }
      }
    },
    "mcpSetup": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "server": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 }
          }
        },
        "id_sequence": { "$ref": "#/$defs/stringArray" },
        "stream_id_sequence": { "$ref": "#/$defs/stringArray" },
        "tools": { "type": "array", "items": { "$ref": "#/$defs/mcpTool" } },
        "resources": { "type": "array", "items": { "$ref": "#/$defs/mcpResource" } },
        "resource_templates": { "type": "array", "items": { "$ref": "#/$defs/mcpResourceTemplate" } },
        "prompts": { "type": "array", "items": { "$ref": "#/$defs/mcpPrompt" } },
        "session_store": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "seed": { "type": "array", "items": { "$ref": "#/$defs/mcpSession" } }
          }
        },
        "task_runtime": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "default_ttl_ms": { "type": "integer" },
            "max_ttl_ms": { "type": "integer" },
            "poll_interval_ms": { "type": "integer" },
            "list_limit": { "type": "integer" },
            "model_immediate_response": { "type": "string" },
            "clock_unix_ms": { "type": "integer" },
            "update_clock_unix_ms": { "type": "integer" }
          }
        }
      }
    },
    "mcpTool": {
      "type": "object",
      "required": ["name", "input_schema", "handler"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "input_schema": {},
        "output_schema": {},
        "handler": { "type": "string", "minLength": 1 },
        "streaming": { "type": "boolean" },
        "task_support": { "type": "string", "enum": ["forbidden", "optional", "required"] }
      }
    },
    "mcpResource": {
      "type": "object",
      "required": ["uri", "name", "contents"],
      "additionalProperties": false,
      "properties": {
        "uri": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "mime_type": { "type": "string" },
        "size": { "type": "integer" },
        "contents": { "type": "array", "items": { "$ref": "#/$defs/mcpResourceContent" } }
      }
    },
    "mcpResourceTemplate": {
      "type": "object",
      "required": ["uri_template", "name"],
      "additionalProperties": false,
      "properties": {
        "uri_template": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "mime_type": { "type": "string" }
      }
    },
    "mcpResourceContent": {
      "type": "object",
      "required": ["uri"],
      "additionalProperties": false,
      "properties": {
        "uri": { "type": "string", "minLength": 1 },
        "mime_type": { "type": "string" },
        "text": { "type": "string" },
        "blob": { "type": "string" }
      }
    },
    "mcpPrompt": {
      "type": "object",
      "required": ["name", "handler"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "arguments": { "type": "array", "items": { "$ref": "#/$defs/mcpPromptArgument" } },
        "handler": { "type": "string", "minLength": 1 }
      }
    },
    "mcpPromptArgument": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "required": { "type": "boolean" }
      }
    },
    "mcpSession": {
      "type": "object",
      "required": ["id", "expires_unix_ms"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "created_unix_ms": { "type": "integer" },
        "expires_unix_ms": { "type": "integer" },
        "data": { "$ref": "#/$defs/stringMap" }
      }
    },
    "openapiSpec": {
      "type": "object",
      "required": ["title", "version", "routes"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "routes": { "type": "array", "items": { "$ref": "#/$defs/openapiRoute" } }
      }
    },
    "openapiRoute": {
      "type": "object",
      "required": ["method", "path", "operation_id", "response"],
      "additionalProperties": false,
      "properties": {
        "method": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "operation_id": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" },
        "tags": { "$ref": "#/$defs/stringArray" },
        "success_status": { "type": "integer" },
        "request": { "$ref": "#/$defs/openapiRequest" },
        "response": { "$ref": "#/$defs/openapiResponse" }
      }
    },
    "openapiRequest": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fields": { "type": "array", "items": { "$ref": "#/$defs/openapiField" } }
      }
    },
    "openapiResponse": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string" },
        "fields": { "type": "array", "items": { "$ref": "#/$defs/openapiField" } }
      }
    },
    "openapiField": {
      "type": "object",
      "required": ["field", "source", "name", "type"],
      "additionalProperties": false,
      "properties": {
        "field": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "enum": ["body", "query", "path", "header", "response"] },
        "name": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "enum": ["string", "integer", "number", "boolean", "object"]
        },
        "array": { "type": "boolean" },
        "required": { "type": "boolean" },
        "validation": {
          "type": "array",
          "items": { "$ref": "#/$defs/openapiValidationRule" }
        }
      }
    },
    "openapiValidationRule": {
      "type": "object",
      "required": ["rule"],
      "additionalProperties": false,
      "properties": {
        "rule": {
          "type": "string",
          "enum": ["required", "min", "max", "min_length", "max_length", "pattern", "enum"]
        },
        "value": {
          "anyOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "array", "items": { "type": ["number", "string"] } }
          ]
        }
      }
    },
    "request": {
      "type": "object",
      "required": ["method", "path", "headers", "body", "is_base64"],
      "additionalProperties": false,
      "properties": {
        "method": { "type": "string" },
        "path": { "type": "string" },
        "query": { "type": "object", "additionalProperties": true },
        "headers": { "type": "object", "additionalProperties": true },
        "body": {},
        "is_base64": { "type": "boolean" }
      }
    },
    "awsEvent": {
      "type": "object",
      "required": ["source", "event"],
      "additionalProperties": false,
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "event": { "type": "object", "additionalProperties": true }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "aws_request_id": { "type": "string" },
        "remaining_ms": { "type": "integer" }
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "request": { "$ref": "#/$defs/request" },
        "aws_event": { "$ref": "#/$defs/awsEvent" },
        "context": { "$ref": "#/$defs/context" },
        "logging_event": { "type": "object", "additionalProperties": true },
        "logging_profile_catalog": { "type": "boolean" },
        "mcp": { "$ref": "#/$defs/mcpInput" },
        "oauth": { "$ref": "#/$defs/oauthInput" }
      }
    },
    "mcpInput": {
      "type": "object",
      "required": ["steps"],
      "additionalProperties": false,
      "properties": {
        "steps": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/mcpStep" } }
      }
    },
    "mcpStep": {
      "type": "object",
      "required": ["name", "request"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "request": { "$ref": "#/$defs/request" },
        "read_body": { "type": "boolean" }
      }
    },
    "response": {
      "type": "object",
      "required": ["status", "headers", "cookies", "is_base64"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "integer" },
        "headers": { "type": "object", "additionalProperties": true },
        "cookies": { "$ref": "#/$defs/stringArray" },
        "body": {},
        "body_json": {},
        "chunks": { "type": "array", "items": {} },
        "is_base64": { "type": "boolean" },
        "stream_error_code": { "type": "string" }
      }
    },
    "expect": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "response": { "$ref": "#/$defs/response" },
        "output_json": {},
        "error": {
          "type": "object",
          "required": ["message"],
          "additionalProperties": false,
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" },
            "status_code": { "type": "integer" }
          }
        },
        "logs": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "metrics": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "spans": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "emf_logs": { "type": "array", "items": { "type": "string" } },
        "ws_calls": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "cloudwatch_logs_subscription": { "type": "object", "additionalProperties": true },
        "profile_logs": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "profile_validation_errors": { "$ref": "#/$defs/stringArray" },
        "logging_profile_catalog": { "type": "object", "additionalProperties": true },
        "microvm_contract_validation": { "type": "object", "additionalProperties": true },
        "microvm_lifecycle_adapter": { "type": "object", "additionalProperties": true },
        "microvm_controller_route": { "type": "object", "additionalProperties": true },
        "microvm_execution_role": { "type": "object", "additionalProperties": true },
        "mcp": { "$ref": "#/$defs/mcpExpect" },
        "oauth": { "$ref": "#/$defs/oauthExpect" }
      }
    },
    "mcpExpect": {
      "type": "object",
      "required": ["steps"],
      "additionalProperties": false,
      "properties": {
        "steps": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/mcpExpectedStep" } }
      }
    },
    "mcpExpectedStep": {
      "type": "object",
      "required": ["status", "headers", "cookies", "is_base64"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "integer" },
        "headers": { "type": "object", "additionalProperties": true },
        "cookies": { "$ref": "#/$defs/stringArray" },
        "body": {},
        "body_json": {},
        "sse_frames": { "type": "array", "items": { "$ref": "#/$defs/mcpSSEFrame" } },
        "is_base64": { "type": "boolean" }
      }
    },
    "mcpSSEFrame": {
      "type": "object",
      "required": ["id", "data"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "event": { "type": "string" },
        "data": { "type": "string" }
      }
    },
    "oauthSetup": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "clock_unix": { "type": "integer" },
        "resource": { "type": "string", "minLength": 1 },
        "authorization_servers": { "$ref": "#/$defs/stringArray" },
        "scopes_supported": { "$ref": "#/$defs/stringArray" },
        "required_audience": { "type": "string" },
        "required_scopes": { "$ref": "#/$defs/stringArray" },
        "bearer_tokens": { "type": "array", "items": { "$ref": "#/$defs/oauthBearerToken" } },
        "id_sequence": { "$ref": "#/$defs/stringArray" },
        "dcr_policy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "allowed_redirect_uris": { "$ref": "#/$defs/stringArray" },
            "require_public_client": { "type": "boolean" },
            "require_refresh_token": { "type": "boolean" }
          }
        }
      }
    },
    "oauthBearerToken": {
      "type": "object",
      "required": ["token"],
      "additionalProperties": false,
      "properties": {
        "token": { "type": "string", "minLength": 1 },
        "subject": { "type": "string" },
        "audience": { "type": "string" },
        "scope": { "type": "string" },
        "scopes": { "$ref": "#/$defs/stringArray" },
        "expires_unix": { "type": "integer" }
      }
    },
    "oauthInput": {
      "type": "object",
      "required": ["steps"],
      "additionalProperties": false,
      "properties": {
        "steps": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/oauthStep" } }
      }
    },
    "oauthStep": {
      "type": "object",
      "required": ["name", "request"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "request": { "$ref": "#/$defs/request" }
      }
    },
    "oauthExpect": {
      "type": "object",
      "required": ["steps"],
      "additionalProperties": false,
      "properties": {
        "steps": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/oauthExpectedStep" } }
      }
    },
    "oauthExpectedStep": {
      "type": "object",
      "required": ["status", "headers", "cookies", "is_base64"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "integer" },
        "headers": { "type": "object", "additionalProperties": true },
        "cookies": { "$ref": "#/$defs/stringArray" },
        "body": {},
        "body_json": {},
        "is_base64": { "type": "boolean" }
      }
    }
  }
}
