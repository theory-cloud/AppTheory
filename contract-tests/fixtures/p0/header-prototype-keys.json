{
  "id": "p0.request.header_prototype_keys",
  "tier": "p0",
  "name": "Prototype-like header names are treated as ordinary headers",
  "setup": {
    "routes": [
      { "method": "GET", "path": "/echo", "handler": "echo_request" }
    ]
  },
  "input": {
    "request": {
      "method": "GET",
      "path": "/echo",
      "query": {},
      "headers": {
        "__proto__": ["proto"],
        "constructor": ["ctor"],
        "X-Foo": ["A"]
      },
      "body": { "encoding": "utf8", "value": "" },
      "is_base64": false
    }
  },
  "expect": {
    "response": {
      "status": 200,
      "headers": { "content-type": ["application/json; charset=utf-8"] },
      "cookies": [],
      "body_json": {
        "method": "GET",
        "path": "/echo",
        "query": {},
        "headers": {
          "__proto__": ["proto"],
          "constructor": ["ctor"],
          "x-foo": ["A"]
        },
        "cookies": {},
        "body_b64": "",
        "is_base64": false
      },
      "is_base64": false
    }
  }
}
