{
  "id": "p0.source_provenance.apigw_v2_malformed_source",
  "tier": "p0",
  "name": "Source provenance: malformed provider source IP is invalid unknown",
  "setup": {
    "routes": [
      {
        "method": "GET",
        "path": "/source",
        "handler": "source_provenance"
      }
    ]
  },
  "input": {
    "request": {
      "method": "GET",
      "path": "/source",
      "query": {},
      "headers": {
        "forwarded": [
          "for=203.0.113.10;proto=https"
        ],
        "x-forwarded-for": [
          "203.0.113.10, 70.0.0.1"
        ]
      },
      "body": {
        "encoding": "utf8",
        "value": ""
