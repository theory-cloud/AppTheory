      },
      {
        "name": "dynamodb_stream ReleaseState REMOVE",
        "attributes": {
          "correlation.id": "stream-obs-2",
          "dynamodb.event_id": "stream-obs-2",
          "dynamodb.event_name": "REMOVE",
          "dynamodb.table_name": "ReleaseState",
