    "spans": [
      {
        "name": "dynamodb_stream ReleaseState MODIFY",
        "attributes": {
          "correlation.id": "stream-obs-1",
          "dynamodb.event_id": "stream-obs-1",
          "dynamodb.event_name": "MODIFY",
          "dynamodb.table_name": "ReleaseState",
          "error.code": "",
          "outcome": "success",
          "trigger": "dynamodb_stream"
