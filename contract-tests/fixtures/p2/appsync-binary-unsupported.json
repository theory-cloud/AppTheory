{
  "id": "p2.appsync.binary_unsupported",
  "tier": "p2",
  "name": "AppSync binary responses return deterministic unsupported errors",
  "setup": {
    "routes": [
      { "method": "GET", "path": "/binaryThing", "handler": "binary_body" }
    ]
  },
  "input": {
    "aws_event": {
      "source": "appsync",
      "event": {
        "arguments": {},
        "info": {
          "fieldName": "binaryThing",
          "parentTypeName": "Query"
        }
      }
    }
  },
  "expect": {
    "output_json": {
      "pay_theory_error": true,
      "error_message": "unsupported appsync response",
      "error_type": "SYSTEM_ERROR",
      "error_data": {
        "status_code": 500,
        "request_id": "req_test_123"
      },
      "error_info": {
        "code": "app.internal",
        "details": {
          "reason": "binary_body_unsupported"
        },
        "path": "/binaryThing",
        "method": "GET",
        "trigger_type": "appsync"
      }
    }
  }
}
