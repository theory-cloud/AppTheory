{
  "id": "p2.appsync.mutation",
  "tier": "p2",
  "name": "AppSync mutation events route through POST handlers",
  "setup": {
    "routes": [
      { "method": "POST", "path": "/createThing", "handler": "parse_json_echo" }
    ]
  },
  "input": {
    "aws_event": {
      "source": "appsync",
      "event": {
        "arguments": {
          "id": "thing_123"
        },
        "info": {
          "fieldName": "createThing",
          "parentTypeName": "Mutation"
        }
      }
    }
  },
  "expect": {
    "output_json": {
      "id": "thing_123"
    }
  }
}
