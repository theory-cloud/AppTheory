{
  "id": "p0.errors.routing_not_found",
  "tier": "p0",
  "name": "Not found uses the canonical AppTheory error envelope",
  "setup": {
    "routes": [
      {
        "method": "GET",
        "path": "/ping",
        "handler": "static_pong"
      }
    ]
  },
  "input": {
    "request": {
      "method": "GET",
      "path": "/missing",
      "query": {},
      "headers": {},
      "body": {
        "encoding": "utf8",
        "value": ""
      },
      "is_base64": false
    }
  },
  "expect": {
    "response": {
      "status": 404,
      "headers": {
        "content-type": [
          "application/json; charset=utf-8"
        ]
      },
      "cookies": [],
      "body_json": {
        "error": {
          "code": "app.not_found",
          "message": "not found"
        }
      },
      "is_base64": false
    }
  }
}
